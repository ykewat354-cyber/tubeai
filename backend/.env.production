# Production environment
# Use hosting platform env vars instead of file in prod

PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-domain.com

DATABASE_URL="postgresql://user:secure_password@db-host:5432/tubeai?sslmode=require"

JWT_SECRET=<use-hosting-platform-secret-manager>
JWT_EXPIRES_IN=7d

OPENAI_API_KEY=<use-hosting-platform-secret-manager>

STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_prod_xxx
STRIPE_PRICE_ID_PRO=price_live_pro_monthly
STRIPE_PRICE_ID_PRO_YEARLY=price_live_pro_yearly
