DATABASE_URL="postgresql://tubeuser:your_password@localhost:5432/tubeai"
JWT_SECRET=dev-secret-change-me
LOG_LEVEL=debug

# OpenAI
OPENAI_API_KEY=sk-dev-key

# Stripe
STRIPE_SECRET_KEY=sk_test_dev
STRIPE_WEBHOOK_SECRET=whsec_dev
