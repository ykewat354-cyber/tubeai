// TubeAI Database Schema
// Version: 2.0 (Analytics + Auth extensions added)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(uuid())
  name             String
  email            String           @unique
  password         String
  emailVerified    Boolean          @default(false)
  verificationToken String?         @unique
  passwordResetCode String?
  passwordResetExp DateTime?
  plan             String           @default("free")
  stripeCustomerId String?          @unique
  stripeSubId      String?          @unique
  subscriptionEnd  DateTime?
  generations      Generation[]
  analyticsEvents  AnalyticsEvent[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([email])
  @@index([stripeCustomerId])
  @@index([verificationToken])
}

model Generation {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     String
  format    String   // "ideas", "titles", "script", "all"
  result    Json     // Actual AI-generated content
  model     String   @default("gpt-4o-mini")
  tokens    Int?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// Analytics events for activity tracking
model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  event     String   // "login", "content_generated", "subscription_change", "history_deleted", "page_view"
  metadata  Json?    // Flexible event data
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([event])
  @@index([createdAt])
  @@index([userId, createdAt])
}
