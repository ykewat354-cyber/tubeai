{
  "name": "tubeai-backend",
  "version": "1.0.0",
  "description": "TubeAI - AI YouTube Idea & Script Generator Backend",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:reset": "npx prisma migrate reset",
    "db:studio": "npx prisma studio",
    "db:seed": "node prisma/seed.js",
    "lint": "eslint src/ --ext .js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "build": "echo \"No build step required for Node.js\""
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov"],
    "collectCoverageFrom": [
      "src/services/**/*.js",
      "src/middleware/**/*.js",
      "src/utils/**/*.js",
      "!src/utils/logger.js"
    ],
    "testPathIgnorePatterns": ["/node_modules/"]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2024": true,
      "jest": true
    },
    "parserOptions": {
      "ecmaVersion": 2024
    },
    "rules": {
      "no-unused-vars": "error",
      "semi": ["error", "always"],
      "quotes": ["error", "double"]
    }
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.60.0",
    "stripe": "^16.10.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "nodemon": "^3.1.4",
    "prisma": "^5.20.0"
  }
}